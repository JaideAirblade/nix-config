# NixOS flake config — per ryan4yin/nixos-and-flakes-book
# flake.lock is generated by `nix flake update`; keep it committed so
# the system is reproducible across machines.
result
result-*
*.qcow2
*.vdi

# Local backups of auto-generated files (kept on disk, not in git)
*.bak-old

# Game logs / launcher configs (not NixOS config)
logs/
launchersettings.json

# Editor / OS cruft
.DS_Store
*.swp
*~